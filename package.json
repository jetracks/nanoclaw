{
  "name": "nanoclaw",
  "version": "1.2.14",
  "description": "Local-first OpenAI assistant with per-group container isolation.",
  "type": "module",
  "workspaces": [
    "ui"
  ],
  "main": "dist/index.js",
  "scripts": {
    "preinstall": "node scripts/ensure-runtime.mjs",
    "guard:runtime": "node scripts/ensure-runtime.mjs",
    "guard:runtime:native": "node scripts/ensure-runtime.mjs --check-native",
    "build": "npm run guard:runtime && npm run build:server && npm run build:ui",
    "build:server": "tsc",
    "build:ui": "npm run build --workspace nanoclaw-ui",
    "start": "node scripts/start.mjs",
    "stop": "node scripts/stop.mjs",
    "restart": "node scripts/restart.mjs",
    "dev": "npm run guard:runtime:native && tsx src/index.ts",
    "dev:ui": "npm run dev --workspace nanoclaw-ui",
    "typecheck": "npm run guard:runtime && tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "npm run guard:runtime:native && tsx setup/index.ts",
    "auth": "npm run guard:runtime:native && tsx src/whatsapp-auth.ts",
    "test": "npm run guard:runtime:native && vitest run",
    "test:watch": "npm run guard:runtime:native && vitest",
    "test:ui": "npm run test --workspace nanoclaw-ui -- --run"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "overrides": {
    "rollup": "4.59.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "22.x"
  }
}
